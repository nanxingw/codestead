{
  "name": "@codestead/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Codestead shared protocol & types: zod v4 single source of truth for daemon and game.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -b tsconfig.build.json --watch",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
