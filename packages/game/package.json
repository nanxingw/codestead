{
  "name": "@codestead/game",
  "version": "0.1.0",
  "private": true,
  "description": "Codestead game client: Phaser 3 + Vite, runs in the browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-map.mjs && node scripts/export-map-meta.mjs && tsc --noEmit && vite build",
    "map:meta": "node scripts/check-map.mjs && node scripts/export-map-meta.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codestead/shared": "workspace:*",
    "idb-keyval": "^6.2.5",
    "phaser": "3.90.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "vite": "^7.3.5"
  }
}
