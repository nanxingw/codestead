{
  // Composite project for `tsc -b` at the repo root: type-checks src and emits
  // declarations only (dist-types/, gitignored). The runnable build is produced by Vite.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "dist-types",
    "types": ["vite/client"]
  },
  "include": ["src"],
  "references": [{ "path": "../shared/tsconfig.build.json" }]
}
